{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 6,
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,

  "modules-left": ["custom/logo", "hyprland/workspaces", "hyprland/window"],
  "modules-center": ["mpris", "clock", "custom/weather"],
  "modules-right": ["custom/launchpad", "tray", "network", "pulseaudio", "battery", "custom/notification"],

  "custom/logo": {
    "format": "пЊѓ",
    "tooltip": false,
    "on-click": "wofi --show drun"
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "в—Џ",
      "default": "в—‹"
    },
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": { "*": 5 }
  },
  "hyprland/window": {
    "format": "{class}",
    "max-length": 35,
    "rewrite": { "^(?!.*\\S).*": "Escritorio" }
  },
  "clock": {
    "format": "{:%d/%m  В·  %H:%M}",
    "tooltip-format": "<big>{:%Y-%m-%d}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "mpris": {
    "format": "{player_icon}  {dynamic}",
    "format-paused": "{status_icon}  {dynamic}",
    "max-length": 28,
    "player-icons": { "default": "пЂЃ", "spotify": "п†ј", "firefox": "п‰©" },
    "status-icons": { "paused": "пЃЊ", "playing": "пЃ‹" },
    "dynamic-order": ["title", "artist"],
    "ignored-players": ["firefox"]
  },
  "custom/weather": {
    "exec": "curl -s --max-time 5 \u0027https://wttr.in/La+Serena?format=%c+%t\u0026lang=es\u0027 2>/dev/null || echo ...",
    "interval": 600,
    "format": "{}",
    "tooltip": false
  },
  "custom/launchpad": {
    "format": "пЂ‰",
    "tooltip": false,
    "on-click": "wofi --show drun"
  },
  "tray": { "icon-size": 16, "spacing": 8 },
  "network": {
    "format-wifi": "п‡« {signalStrength}%",
    "format-ethernet": "п›ї",
    "format-disconnected": "п•©",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname} via {gwaddr}",
    "tooltip-format-disconnected": "Desconectado",
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon}  {volume}%",
    "format-muted": "пљ©",
    "format-icons": { "default": ["пЂ§", "пЂ§", "пЂЁ"] },
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },
  "battery": {
    "states": { "warning": 30, "critical": 15 },
    "format": "{icon} {capacity}%",
    "format-charging": "пѓ§ {capacity}%",
    "format-plugged": "п‡¦ {capacity}%",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
  },
  "custom/notification": {
    "format": "пѓі",
    "on-click": "swaync-client -t",
    "tooltip": false
  }
}
