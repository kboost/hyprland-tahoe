{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 6,
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,
  "modules-left": [
    "custom/logo",
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "mpris",
    "clock",
    "custom/weather"
  ],
  "modules-right": [
    "custom/launchpad",
    "tray",
    "network",
    "pulseaudio",
    "battery",
    "custom/notification",
    "custom/power"
  ],
  "custom/logo": {
    "format": "",
    "tooltip": false,
    "on-click": "wofi --show drun"
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "●",
      "default": "○"
    },
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
      "*": 5
    }
  },
  "hyprland/window": {
    "format": "{class}",
    "max-length": 35,
    "rewrite": {
      "^(?!.*\\S).*": "Escritorio"
    }
  },
  "clock": {
    "format": "{:%d/%m  ·  %H:%M}",
    "tooltip-format": "<big><b>{0:%d/%m/%Y  ·  %H:%M}</b></big>\n<small>{0:%A   ·   semana %V}</small>\n\n<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "right",
      "format": {
        "months":   "<b>{}</b>",
        "weekdays": "<b>{}</b>",
        "today":    "<b><span color='#5ac8fa'>{}</span></b>"
      }
    }
  },
  "mpris": {
    "format": "{player_icon}  {dynamic}",
    "format-paused": "{status_icon}  {dynamic}",
    "tooltip-format": "<b>{title}</b>\n{artist}\n<small>{album}  ·  {player}</small>",
    "tooltip-format-paused": "<b>{title}</b>\n{artist}\n<small>{album}  ·  {player} (pausado)</small>",
    "max-length": 28,
    "player-icons": {
      "default": "",
      "spotify": "",
      "firefox": ""
    },
    "status-icons": {
      "paused": "",
      "playing": ""
    },
    "dynamic-order": [
      "title",
      "artist"
    ],
    "ignored-players": [
      "firefox"
    ]
  },
  "custom/weather": {
    "exec": "~/.config/waybar/scripts/weather.sh",
    "return-type": "json",
    "interval": 180,
    "signal": 8,
    "format": "{}",
    "tooltip": true
  },
  "custom/launchpad": {
    "format": "",
    "tooltip": false,
    "on-click": "wofi --show drun"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 8
  },
  "network": {
    "format-wifi": " {signalStrength}%",
    "format-ethernet": "",
    "format-disconnected": "",
    "tooltip-format-wifi": "<b>{essid}</b>  ·  {signalStrength}%\nIP\t{ipaddr}\nGateway\t{gwaddr}\n↓ {bandwidthDownBytes}\t↑ {bandwidthUpBytes}",
    "tooltip-format-ethernet": "<b>{ifname}</b>  ·  Cableado\nIP\t{ipaddr}\nGateway\t{gwaddr}\n↓ {bandwidthDownBytes}\t↑ {bandwidthUpBytes}",
    "tooltip-format-disconnected": "Desconectado",
    "on-click": "eww open --toggle netmenu",
    "interval": 2
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon}  {volume}%",
    "format-muted": "",
    "format-icons": {
      "default": [
        "",
        "",
        ""
      ]
    },
    "on-click": "eww open --toggle volmenu",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-plugged": " {capacity}%",
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ]
  },
  "custom/notification": {
    "format": "",
    "on-click": "swaync-client -t",
    "tooltip": false
  },
  "custom/power": {
    "format": "",
    "tooltip": false,
    "on-click": "eww open --toggle powermenu"
  }
}